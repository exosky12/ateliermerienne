{
	"extends": "@adonisjs/tsconfig/tsconfig.app.json",
	"compilerOptions": {
		"rootDir": "./",
		"outDir": "./build",
		"paths": {
			"#core/*": ["./app/core/*"],
			"#features/*": ["./app/features/*"],
			"#infrastructure/*": ["./app/infrastructure/*"],
			"#controllers/*": ["./app/infrastructure/controllers/*"],
			"#exceptions/*": ["./app/infrastructure/exceptions/*"],
			"#models/*": ["./app/infrastructure/models/*"],
			"#mails/*": ["./app/mails/*"],
			"#services/*": ["./app/services/*"],
			"#shared/*": ["./app/shared/*"],
			"#listeners/*": ["./app/listeners/*"],
			"#events/*": ["./app/events/*"],
			"#middleware/*": ["./app/infrastructure/middleware/*"],
			"#validators/*": ["./app/infrastructure/validators/*"],
			"#providers/*": ["./providers/*"],
			"#policies/*": ["./app/policies/*"],
			"#abilities/*": ["./app/abilities/*"],
			"#database/*": ["./database/*"],
			"#start/*": ["./start/*"],
			"#tests/*": ["./tests/*"],
			"#config/*": ["./config/*"]
		}
	}
}
