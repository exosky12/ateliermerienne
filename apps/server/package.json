{
	"name": "@apps/server",
	"type": "module",
	"version": "0.0.0",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"start": "node bin/server.js",
		"build": "node ace build",
		"dev": "node ace serve --hmr",
		"test": "node ace test",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"format": "prettier --write ."
	},
	"imports": {
		"#app/*": "./app/*.js",
		"#identity/*": "./app/identity/*.js",
		"#exceptions/*": "./app/exceptions/*.js",
		"#mails/*": "./app/mails/*.js",
		"#services/*": "./app/services/*.js",
		"#shared/*": "./app/shared/*.js",
		"#listeners/*": "./app/listeners/*.js",
		"#events/*": "./app/events/*.js",
		"#middleware/*": "./app/middleware/*.js",
		"#validators/*": "./app/validators/*.js",
		"#providers/*": "./providers/*.js",
		"#policies/*": "./app/policies/*.js",
		"#abilities/*": "./app/abilities/*.js",
		"#database/*": "./database/*.js",
		"#start/*": "./start/*.js",
		"#tests/*": "./tests/*.js",
		"#config/*": "./config/*.js",
		"#generated/*": "./.adonisjs/server/*.js",
		"#transformers/*": "./app/transformers/*.js"
	},
	"exports": {
		"./api": "./.adonisjs/index.ts"
	},
	"devDependencies": {
		"@adonisjs/assembler": "latest",
		"@adonisjs/tsconfig": "latest",
		"@japa/api-client": "^3.1.0",
		"@japa/assert": "^4.0.1",
		"@japa/plugin-adonisjs": "latest",
		"@japa/runner": "^4.2.0",
		"@packages/config": "workspace:*",
		"@poppinss/ts-exec": "^1.4.4",
		"@tuyau/utils": "^0.0.9",
		"@types/luxon": "^3.7.1",
		"@types/node": "^22.15.18",
		"eslint": "catalog:",
		"hot-hook": "^0.4.0",
		"pino-pretty": "^13.0.0",
		"prettier": "catalog:",
		"typescript": "catalog:",
		"youch": "^4.1.0"
	},
	"dependencies": {
		"@adonisjs/auth": "latest",
		"@adonisjs/core": "latest",
		"@adonisjs/cors": "latest",
		"@adonisjs/lucid": "latest",
		"@adonisjs/session": "latest",
		"@tuyau/core": "^1.0.0",
		"@tuyau/react-query": "0.0.1-next.2",
		"@tuyau/superjson": "^0.1.2",
		"@vinejs/vine": "latest",
		"luxon": "^3.7.2",
		"pg": "^8.16.3",
		"reflect-metadata": "^0.2.2"
	},
	"hotHook": {
		"boundaries": [
			"./app/infrastructure/controllers/**/*.ts",
			"./app/infrastructure/middleware/*.ts"
		]
	}
}
